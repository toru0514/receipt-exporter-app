# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-generate-with-openssl-rand-base64-32

# Google Gemini API Key (optional: if not set, uses OAuth token)
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Cron Job Secret (for /api/cron endpoint authentication)
CRON_SECRET=your-cron-secret-generate-with-openssl-rand-base64-32

# microCMS (領収書画像管理)
MICROCMS_SERVICE_DOMAIN=your-microcms-service-domain
MICROCMS_API_KEY=your-microcms-api-key
